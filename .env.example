# ===========================================
# 환경 변수 템플릿
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 키 값을 채워 넣으세요.
#   cp .env.example .env
# .env 는 git 에 커밋되지 않습니다 (.gitignore 처리됨).
# ===========================================

# OpenAI API 키 (LLM-as-a-Judge, GPT-4 평가 등에서 사용)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# HuggingFace 액세스 토큰 (gated 모델 다운로드 / Hub 업로드 시 필요)
# 발급: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...
